ts/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">CREATE TABLE IF NOT EXISTS users (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    username TEXT UNIQUE NOT NULL,
    password TEXT NOT NULL,
    prefix TEXT NOT NULL,         -- คำนำหน้าชื่อ เช่น นาย, นาง, นางสาว
    first_name TEXT NOT NULL,     -- ชื่อจริง
    last_name TEXT NOT NULL,      -- นามสกุล
    role TEXT NOT NULL,           -- สิทธิ์การใช้งาน: admin, director, teacher
    target_group TEXT NOT NULL,   -- ขอบเขตข้อมูลที่เห็น: ALL หรือ ระดับชั้น เช่น ป.1
    status TEXT DEFAULT 'active'  -- สถานะบัญชี: active, inactive
);
</sql><sql name="SQL 2*">INSERT OR IGNORE INTO users (username, password, prefix, first_name, last_name, role, target_group) 
VALUES 
('admin01', 'adminpass', 'นาย', 'สมศักดิ์', 'ระบบดีเยี่ยม', 'admin', 'ALL'),
('director_suthat', 'dir123', 'นาย', 'สุทัศน์', 'จันทรัตน์', 'director', 'ALL'),
('teacher_p1', 'tea456', 'นางสาว', 'ใจดี', 'เรียนเก่ง', 'teacher', 'ป.1'),
('teacher_p2', 'tea789', 'นาง', 'สมศรี', 'รักเด็ก', 'teacher', 'ป.2');</sql><current_tab id="1"/></tab_sql></sqlb_project>
